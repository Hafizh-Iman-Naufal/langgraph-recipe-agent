# Required LLM config
# Supported providers: google (Gemini), openai (ChatGPT)
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash-lite

# Google Gemini API Key (required if LLM_PROVIDER=google)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# Optional: Alternative key name (use either GOOGLE_API_KEY or GEMINI_API_KEY)
# GEMINI_API_KEY=

# OpenAI API Key (required if LLM_PROVIDER=openai)
# OPENAI_API_KEY=

# Optional YouTube integration
# If this is empty or missing, the project must still work.
YOUTUBE_API_KEY=

# Default recipe agent config
DEFAULT_LANGUAGE=auto
DEFAULT_OUTPUT_MODE=print
DEFAULT_TASK_TYPE=recommend_then_recipe
DEFAULT_RECOMMENDATION_COUNT=10
DEFAULT_MAX_REVISIONS=3
DEFAULT_APPROVAL_THRESHOLD=0.85
DEFAULT_RECOMMENDATION_THRESHOLD=0.80
DEFAULT_INCLUDE_VIDEO_URLS=false
DEFAULT_MAX_VIDEO_URLS=5
